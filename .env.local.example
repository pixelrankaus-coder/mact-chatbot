# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api

# Public URL - safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anonymous key - safe to expose in browser (has row-level security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key - KEEP SECRET! Only use server-side
# This key bypasses row-level security
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Email Notifications (Resend)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key-here

# Comma-separated list of emails to receive notifications
NOTIFICATION_EMAIL=your-email@example.com

# Email "from" address (must be verified in Resend, or use default)
EMAIL_FROM=MACt Chatbot <notifications@yourdomain.com>

# Public app URL (for inbox links in emails)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
